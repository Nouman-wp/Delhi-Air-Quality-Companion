# Server
PORT=4000
CLIENT_ORIGIN=http://localhost:5173
JWT_SECRET=change-this-to-a-long-random-string
NODE_ENV=development

# Elasticsearch (Elastic Cloud or self-hosted). If omitted, the app runs on an
# in-memory data store so it still functions end-to-end without Elastic set up.
ELASTICSEARCH_NODE=
ELASTICSEARCH_API_KEY=
# Alternative to API key auth:
ELASTICSEARCH_USERNAME=
ELASTICSEARCH_PASSWORD=

# AQI provider - World Air Quality Index (https://aqicn.org/data-platform/token/)
# Free instant token. Without it, realistic simulated AQI data is served instead.
WAQI_TOKEN=

# Weather - Open-Meteo requires no API key at all (used by default).

# Routing - OSRM's public demo server (driving only) and geocoding - Nominatim
# (OpenStreetMap). Both are free and require no API key or signup at all.

# AI chat - OpenRouter (https://openrouter.ai/keys). Gateway to many LLMs,
# including generous free models. Without it, the chat falls back to a
# rule-based health-advisory responder.
OPENROUTER_API_KEY=
# Any model slug from https://openrouter.ai/models. Defaults to a free Llama
# model if unset. Free models end in ":free"; paid ones bill your OpenRouter
# credits per token.
OPENROUTER_MODEL=openai/gpt-oss-20b:free
