# Mapbox GL JS access token (https://account.mapbox.com/access-tokens/)
# Without this, the Map page falls back to a list-based view instead of the
# interactive satellite map.
VITE_MAPBOX_TOKEN=

# Backend API base URL. Leave unset in development — Vite proxies /api to
# http://localhost:4000 automatically (see vite.config.ts).
VITE_API_BASE_URL=
        